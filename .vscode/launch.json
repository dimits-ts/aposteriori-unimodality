{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Annotation Analysis",
            "type": "debugpy",
            "request": "launch",
            "module": "src.annotation_analysis",
            "args": [
                "--synthetic-path=data/annotation.csv",
                "--kumar-path=data/kumar.json"
            ],
        },
        {
            "name": "Python Debugger: Kumar",
            "type": "debugpy",
            "request": "launch",
            "module": "src.kumar",
            "args": [
                "--dataset-path=data/kumar.json",
                "--output-dir=output",
                "--graph-output-dir=graphs"
            ],
        },
        {
            "name": "Python Debugger: Dices",
            "type": "debugpy",
            "request": "launch",
            "module": "src.dices",
            "args": [
                "--dataset-path-small=data/dices/350/diverse_safety_adversarial_dialog_350.csv",
                "--dataset-path-large=data/dices/990/diverse_safety_adversarial_dialog_990.csv",
                "--output-dir=output",
                "--graph-output-dir=graphs"
            ]
        },
        {
            "name": "Python Debugger: Synthetic",
            "type": "debugpy",
            "request": "launch",
            "module": "src.synthetic",
            "args": [
                "--dataset-path=data/annotation.csv",
                "--output-dir=output",
                "--graph-output-dir=graphs"
            ],
        },
        {
            "name": "Debug real_life_sap",
            "type": "debugpy",
            "request": "launch",
            "module": "src.real_life_sap",
            "justMyCode": true,
            "args": [
                "--dataset-path=data/sap.csv",
                "--output-dir=output",
                "--graph-output-dir=graphs"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}